<Window x:Class="TouristDestinations_Component1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Tourist Destinations" Height="700" Width="1100">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <RadioButton Content="XML" GroupName="Format" IsChecked="True"
                         Command="{Binding SelectFormatCommand}" CommandParameter="XML" Margin="5"/>
            <RadioButton Content="JSON" GroupName="Format"
                         Command="{Binding SelectFormatCommand}" CommandParameter="JSON" Margin="5"/>
            <Button Content="Load" Command="{Binding LoadCommand}" Margin="5" Width="60"/>
            <Button Content="Save" Command="{Binding SaveCommand}" Margin="5" Width="60"/>
        </StackPanel>

        <TabControl Grid.Row="1" Margin="10">

            <TabItem Header="Destinations" DataContext="{Binding DestinationViewModel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="97*"/>
                            <ColumnDefinition Width="677*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Margin="5,5,5,5"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2"/>

                        <DataGrid Grid.Row="1" Margin="5,5,5,5"
                                  ItemsSource="{Binding Destinations}"
                                  SelectedItem="{Binding SelectedDestination}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" Grid.ColumnSpan="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5,5,5,5" Grid.ColumnSpan="2">
                            <Button Content="Undo" Command="{Binding UndoCommand}" Width="60" Margin="5"/>
                            <Button Content="Redo" Command="{Binding RedoCommand}" Width="60" Margin="5"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Name" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <TextBlock Text="Country" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputCountry, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <TextBlock Text="Type" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <Button Content="Add" Command="{Binding AddCommand}" Margin="0,10,0,5"/>
                        <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,5"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Visits" DataContext="{Binding VisitViewModel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Margin="5"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Margin="5" FontWeight="Bold"/>

                        <DataGrid Grid.Row="2" Margin="5"
                                  ItemsSource="{Binding Visits}"
                                  SelectedItem="{Binding SelectedVisit}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Destination" Binding="{Binding DestinationName}" Width="*"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding DateOfVisit, StringFormat=dd.MM.yyyy}" Width="*"/>
                                <DataGridTextColumn Header="Visitors" Binding="{Binding NumberOfVisitors}" Width="*"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding DurationOfVisit}" Width="*"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=C}" Width="*"/>
                                <DataGridTextColumn Header="State" Binding="{Binding StateType}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5">
                            <Button Content="Undo" Command="{Binding UndoCommand}" Width="60" Margin="5"/>
                            <Button Content="Redo" Command="{Binding RedoCommand}" Width="60" Margin="5"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="10">
                        <TextBlock Text="Destination" Margin="0,5,0,2"/>
                        <ComboBox ItemsSource="{Binding Destinations}"
                                  SelectedItem="{Binding SelectedDestination}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,5"/>

                        <TextBlock Text="Date of Visit" Margin="0,5,0,2"/>
                        <DatePicker SelectedDate="{Binding InputDateOfVisit}" Margin="0,0,0,5"/>

                        <TextBlock Text="Number of Visitors" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputNumberOfVisitors, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <TextBlock Text="Duration (days)" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputDurationOfVisit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <TextBlock Text="Revenue" Margin="0,5,0,2"/>
                        <TextBox Text="{Binding InputRevenue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                        <Button Content="Add" Command="{Binding AddCommand}" Margin="0,10,0,5"/>
                        <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,5"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,5"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Chart" DataContext="{Binding ChartViewModel}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <lvc:PieChart Grid.Row="0" Series="{Binding Series}" 
                      TooltipPosition="Hidden"
                      Margin="10"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <Rectangle Fill="Green" Width="15" Height="15" Margin="5,0"/>
                        <TextBlock Text="Popular" Margin="0,0,15,0"/>
                        <Rectangle Fill="Blue" Width="15" Height="15" Margin="5,0"/>
                        <TextBlock Text="Stable" Margin="0,0,15,0"/>
                        <Rectangle Fill="Orange" Width="15" Height="15" Margin="5,0"/>
                        <TextBlock Text="Decline" Margin="0,0,15,0"/>
                        <Rectangle Fill="Red" Width="15" Height="15" Margin="5,0"/>
                        <TextBlock Text="OffSeason" Margin="0,0,15,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>