<Window x:Class="TouristDestinations_Component1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Tourist Destinations" Height="700" Width="1100">

    <Window.Resources>

        <SolidColorBrush x:Key="PrimaryBrush" Color="#2E4057"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4A017"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                        Background="#2E4057"
                        BorderBrush="#D4A017"
                        BorderThickness="1"
                        Padding="15,8">

                            <ContentPresenter
                        ContentSource="Header"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#D4A017"/>
                                <Setter Property="Foreground"
                                Value="Black"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="Background"
                                Value="#4A658A"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#F8F8F8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#F8F8F8"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#F8F8F8"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#EDF2F7"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F1F1F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Window.Resources>

    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="Assets/background1.jpeg"
                    Stretch="UniformToFill"
                    Opacity="0.55"/>
        </Grid.Background>
        <Border Background="Transparent"
        BorderBrush="#D4A017"
        BorderThickness="2"
        CornerRadius="12"
        Margin="10">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="15,10,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">
                        <RadioButton Content="XML"
                     GroupName="Format"
                     IsChecked="True"
                     Command="{Binding SelectFormatCommand}"
                     CommandParameter="XML"
                     Margin="5" Height="16"/>

                        <RadioButton Content="JSON"
                     GroupName="Format"
                     Command="{Binding SelectFormatCommand}"
                     CommandParameter="JSON"
                     Margin="5" Height="17"/>
                        <Button Content="Load"
        Command="{Binding LoadCommand}"
        Width="80"
        Height="35"/>

                        <Button Content="Save"
        Command="{Binding SaveCommand}"
        Width="80"
        Height="35"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                Orientation="Horizontal"/>
                </Grid>
                <TabControl Grid.Row="1"
            Margin="10"
            Background="Transparent"
            BorderBrush="#D4A017"
            BorderThickness="2">
                    <TabItem Header="Destinations" DataContext="{Binding DestinationViewModel}">
                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0" Background="#CCFFFFFF">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="97*"/>
                                    <ColumnDefinition Width="677*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0" Margin="5,5,5,5"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Grid.ColumnSpan="2"/>

                                <DataGrid Grid.Row="1" Margin="5,5,5,5" RowBackground="White"
AlternatingRowBackground="#EDF2F7"
GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding Destinations}"
                                  SelectedItem="{Binding SelectedDestination}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True" Grid.ColumnSpan="2">

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                        <DataGridTextColumn Header="Country" Binding="{Binding Country}" Width="*"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Grid.Row="2" Orientation="Horizontal" Background="#CCFFFFFF" Margin="5,5,5,5" Grid.ColumnSpan="2">
                                    <Button Content="Undo" Command="{Binding UndoCommand}" Width="60" Margin="5"/>
                                    <Button Content="Redo" Command="{Binding RedoCommand}" Width="60" Margin="5"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="Name" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <TextBlock Text="Country" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputCountry, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <TextBlock Text="Type" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputType, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <Button Content="Add" Command="{Binding AddCommand}" Margin="0,10,0,5"/>
                                <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,5"/>
                                <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,5"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Visits" DataContext="{Binding VisitViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>

                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0" Margin="5"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Margin="5" FontWeight="Bold"/>

                                <DataGrid Grid.Row="2" Margin="5" RowBackground="White"
AlternatingRowBackground="#EDF2F7"
GridLinesVisibility="Horizontal"
                                  ItemsSource="{Binding Visits}"
                                  SelectedItem="{Binding SelectedVisit}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Destination" Binding="{Binding DestinationName}" Width="*"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding DateOfVisit, StringFormat=dd.MM.yyyy}" Width="*"/>
                                        <DataGridTextColumn Header="Visitors" Binding="{Binding NumberOfVisitors}" Width="*"/>
                                        <DataGridTextColumn Header="Duration" Binding="{Binding DurationOfVisit}" Width="*"/>
                                        <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=C}" Width="*"/>
                                        <DataGridTextColumn Header="State" Binding="{Binding StateType}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="5">
                                    <Button Content="Undo" Command="{Binding UndoCommand}" Width="60" Margin="5"/>
                                    <Button Content="Redo" Command="{Binding RedoCommand}" Width="60" Margin="5"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="Destination" Margin="0,5,0,2"/>
                                <ComboBox ItemsSource="{Binding Destinations}"
                                  SelectedItem="{Binding SelectedDestination}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,5"/>

                                <TextBlock Text="Date of Visit" Margin="0,5,0,2"/>
                                <DatePicker SelectedDate="{Binding InputDateOfVisit}" Margin="0,0,0,5"/>

                                <TextBlock Text="Number of Visitors" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputNumberOfVisitors, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <TextBlock Text="Duration (days)" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputDurationOfVisit, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <TextBlock Text="Revenue" Margin="0,5,0,2"/>
                                <TextBox Text="{Binding InputRevenue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,5"/>

                                <Button Content="Add" Command="{Binding AddCommand}" Margin="0,10,0,5"/>
                                <Button Content="Edit" Command="{Binding EditCommand}" Margin="0,5"/>
                                <Button Content="Delete" Command="{Binding DeleteCommand}" Margin="0,5"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Chart" DataContext="{Binding ChartViewModel}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <lvc:PieChart Grid.Row="0" Series="{Binding Series}" 
                      TooltipPosition="Hidden"
                      Margin="10"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                                <Rectangle Fill="Green" Width="15" Height="15" Margin="5,0"/>
                                <TextBlock Text="Popular" Margin="0,0,15,0"/>
                                <Rectangle Fill="Blue" Width="15" Height="15" Margin="5,0"/>
                                <TextBlock Text="Stable" Margin="0,0,15,0"/>
                                <Rectangle Fill="Orange" Width="15" Height="15" Margin="5,0"/>
                                <TextBlock Text="Decline" Margin="0,0,15,0"/>
                                <Rectangle Fill="Red" Width="15" Height="15" Margin="5,0"/>
                                <TextBlock Text="OffSeason" Margin="0,0,15,0"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>
    </Grid>
</Window>